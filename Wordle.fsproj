<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Wordle</RootNamespace>
    <AssemblyName>Wordle</AssemblyName>
    <Nullable>disable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="src/Types.fs" />
    <Compile Include="src/WordList.fs" />
    <Compile Include="src/Scoring.fs" />
    <Compile Include="src/Stats.fs" />
    <Compile Include="src/Tui.fs" />
    <Compile Include="src/Game.fs" />
    <Compile Include="src/Program.fs" />
  </ItemGroup>

  <ItemGroup>
    <None Include="assets/words.txt" Link="words.txt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="assets/words-ranked.txt" Link="words-ranked.txt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <EmbeddedResource Include="assets/words.txt">
      <LogicalName>words.txt</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="assets/words-ranked.txt">
      <LogicalName>words-ranked.txt</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

</Project>
